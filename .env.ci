# CI/CD Environment Variables for GitHub Actions

# Application
ENVIRONMENT=test
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite for tests)
DATABASE_URL=sqlite:///./test_rag.db

# LLM Providers (Optional for CI - can use mocks)
OPENAI_API_KEY=test-key-ci
GROQ_API_KEY=test-key-ci
HF_TOKEN=test-token-ci

# Vector Database
FAISS_INDEX_PATH=data/vector_index

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Quality Settings
MIN_QUALITY_THRESHOLD=0.70
DEFAULT_TOP_K=5
MAX_CONTEXT_LENGTH=4000

# Performance
CACHE_ENABLED=false
CACHE_TTL_MINUTES=60

# Security (for tests)
JWT_SECRET_KEY=test-secret-key-for-ci-only
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Testing
PYTEST_TIMEOUT=300
TEST_DATABASE=sqlite:///./test_rag.db
