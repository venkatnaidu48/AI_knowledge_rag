# ============================================
# RAG APPLICATION - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============ Application Settings ============
APP_NAME=RAG-Knowledge-Worker
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=False

# ============ API Settings ============
API_TITLE=RAG Query API
API_DESCRIPTION=Enterprise RAG System for Company Document Q&A
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# ============ Database Settings ============
# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ============ Redis Settings ============
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600
REDIS_MAX_CONNECTIONS=50

# ============ OpenAI Settings ============
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_TIMEOUT=30

# LLM Models
PRIMARY_LLM_MODEL=gpt-4
FALLBACK_LLM_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# LLM Parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500
LLM_TOP_P=0.95

# ==============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# ==============================================================================
# Primary Database (PostgreSQL)
DB_DRIVER=postgresql
DB_USER=ragapp_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragapp_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false  # Set to true for SQL logging

# Optional: MongoDB for flexible document schema
MONGO_ENABLED=false
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ragapp_mongo

# ==============================================================================
# VECTOR DATABASE CONFIGURATION
# ==============================================================================
# FAISS Configuration (Local Vector Store)
VECTOR_DB_TYPE=faiss  # Options: faiss, pinecone, weaviate, chroma
VECTOR_DB_PATH=./data/vector_store
VECTOR_INDEX_NAME=document_index
VECTOR_SIMILARITY_METRIC=cosine  # Options: cosine, euclidean, dot_product

# Alternative: Pinecone Cloud
# VECTOR_DB_TYPE=pinecone
# PINECONE_API_KEY=your_pinecone_key_here
# PINECONE_ENVIRONMENT=us-west1-gcp
# PINECONE_INDEX_NAME=ragapp-index

# Vector Search Parameters
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.5
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ==============================================================================
# DOCUMENT STORAGE CONFIGURATION
# ==============================================================================
# Local Storage
DOCUMENT_STORAGE_TYPE=local  # Options: local, s3, gcs, azure
DOCUMENT_UPLOAD_DIR=./knowledge_base
DOCUMENT_MAX_SIZE_MB=100
DOCUMENT_ALLOWED_TYPES=pdf,docx,txt,xlsx,pptx

# AWS S3 Storage (Optional)
# DOCUMENT_STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your_aws_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_here
# AWS_S3_BUCKET=ragapp-documents
# AWS_REGION=us-east-1

# ==============================================================================
# CACHING CONFIGURATION
# ==============================================================================
# Redis Cache
CACHE_ENABLED=true
CACHE_TYPE=redis  # Options: redis, memcached, inmemory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if no password
REDIS_DB=0

# Cache TTLs (in seconds)
CACHE_QUERY_RESULTS_TTL=300  # 5 minutes
CACHE_EMBEDDINGS_TTL=2592000  # 30 days
CACHE_VECTOR_TTL=86400  # 1 day

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7

# API Key Management
API_KEY_ENABLED=true
API_KEY_HEADER=X-API-Key

# HTTPS & SSL
ENABLE_HTTPS=false  # Set to true in production
SSL_CERT_PATH=/etc/ssl/certs/your_cert.pem
SSL_KEY_PATH=/etc/ssl/private/your_key.pem

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100  # Requests per minute
RATE_LIMIT_WINDOW=60    # Time window in seconds

# Per-endpoint rate limits
RATE_LIMIT_QUERY_REQUESTS=30
RATE_LIMIT_UPLOAD_REQUESTS=10
RATE_LIMIT_ADMIN_REQUESTS=50

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
# Log Format
LOG_FORMAT=json  # Options: json, text
LOG_LEVEL=INFO

# File Logging
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=100  # MB
LOG_FILE_BACKUP_COUNT=10

# Sentry Error Tracking
SENTRY_ENABLED=false
SENTRY_DSN=your_sentry_dsn_here
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==============================================================================
# MONITORING & METRICS
# ==============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_ENABLED=true

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30  # seconds
HEALTH_CHECK_TIMEOUT=10   # seconds

# ==============================================================================
# DOCUMENT PROCESSING
# ==============================================================================
# Chunk Configuration
CHUNK_SIZE=512        # Tokens per chunk
CHUNK_OVERLAP=0.1     # 10% overlap
CHUNK_MIN_SIZE=100    # Minimum chunk size

# OCR Configuration (for scanned documents)
OCR_ENABLED=true
OCR_ENGINE=pytesseract  # Options: pytesseract, easyocr, paddle
OCR_CONFIDENCE_THRESHOLD=0.5

# Text Preprocessing
TEXT_PREPROCESSING_ENABLED=true
REMOVE_SPECIAL_CHARS=true
NORMALIZE_WHITESPACE=true

# ==============================================================================
# HALLUCINATION MITIGATION
# ==============================================================================
HALLUCINATION_DETECTION_ENABLED=true
CONFIDENCE_THRESHOLD=0.7  # Confidence score threshold for responses
SOURCE_ATTRIBUTION_REQUIRED=true
UNCERTAINTY_THRESHOLD=0.3  # Response uncertainty threshold

# ==============================================================================
# AUDIT & COMPLIANCE
# ==============================================================================
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
PII_DETECTION_ENABLED=false
DATA_ENCRYPTION_ENABLED=false  # Set to true for sensitive deployments

# ==============================================================================
# DOCUMENT UPDATE STRATEGY
# ==============================================================================
# Real-time vs Batch Updates
UPDATE_MODE=batch  # Options: realtime, batch, scheduled

# Batch Update
BATCH_UPDATE_INTERVAL=3600  # Seconds (1 hour)
BATCH_UPDATE_SIZE=50        # Documents per batch

# Scheduled Update
SCHEDULE_ENABLED=true
SCHEDULE_TIME=02:00  # Daily update at 2 AM

# ==============================================================================
# BACKUP & RECOVERY
# ==============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # Daily
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=./backups

# ==============================================================================
# EXTERNAL SERVICES INTEGRATION
# ==============================================================================
# Slack Integration
SLACK_INTEGRATION_ENABLED=false
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Email Notifications
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=noreply@company.com

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
FEATURE_STREAMING_ENABLED=true
FEATURE_FEEDBACK_LOOP_ENABLED=true
FEATURE_PARALLEL_RETRIEVAL_ENABLED=true
FEATURE_HYBRID_SEARCH_ENABLED=false
FEATURE_RERANKING_ENABLED=true

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================
# Workers & Threading
WORKER_THREADS=4
EMBEDDING_WORKER_THREADS=2
RETRIEVAL_TIMEOUT_SECONDS=10

# Memory Management
ENABLE_MEMORY_OPTIMIZATION=true
MAX_MEMORY_MB=4096
GC_COLLECTION_INTERVAL=1800  # 30 minutes
