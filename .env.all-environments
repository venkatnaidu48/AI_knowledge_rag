# ============================================================================
# 1. APPLICATION SETTINGS
# ============================================================================
# What: Basic app configuration and identification
# Where: Used in logs, API responses, and startup messages

# APP_NAME - Application name for identification
# Used in: Logs, metrics, API documentation
# Example: "RAG-Knowledge-Worker"

# APP_VERSION - Semantic version number (MAJOR.MINOR.PATCH)
# Used in: API responses, documentation
# Example: "1.0.0"

# DEBUG - Enable debug mode with detailed error messages
# ⚠️ CRITICAL: Always FALSE in production!
# Development: true (shows detailed errors for debugging)
# Production: false (hides sensitive information)
# Effect: Enables/disables stack traces, verbose logging

# ENVIRONMENT - Deployment environment name
# Values: development, staging, production
# Controls: Logging behavior, caching strategy, error handling
# Development: development (allows testing shortcuts)
# Production: production (strict validation, error handling)

# API_TITLE - Title shown in Swagger/OpenAPI documentation
# Example: "RAG Query API"

# API_DESCRIPTION - Description shown in Swagger documentation
# Example: "Enterprise RAG System for Company Document Q&A"

# API_HOST - Network interface to listen on
# Values: 127.0.0.1 (localhost only) or 0.0.0.0 (all interfaces)
# Development: 127.0.0.1 (security - only accessible locally)
# Production: 0.0.0.0 (accessible from load balancer)
# Docker: 0.0.0.0 (needs external access from host)

# API_PORT - TCP port number for the server
# Range: 1024-65535 (avoid 1-1023 unless running as root)
# Default: 8000
# Must be available on your system

# API_WORKERS - Number of worker processes
# More workers = handles more concurrent requests
# Rule: (2 * CPU_cores) + 1
# Development: 1 (single worker, simpler)
# Production: 4-8 (handle production traffic)
# Docker: 2 (container-based)

# API_LOG_LEVEL - Server logging verbosity
# Values: debug, info, warning, error, critical
# Development: debug (show everything)
# Production: warning (only important messages)


# ============================================================================
# 2. DATABASE CONFIGURATION
# ============================================================================
# What: Persistent data storage (conversations, metadata)
# Why: Store system state and user data

# DATABASE_URL - Connection string to database
# Formats:
#   SQLite:     sqlite:///./rag_dev.db
#   PostgreSQL: postgresql://user:password@host:port/dbname
#   MySQL:      mysql+pymysql://user:password@host:port/dbname
# Development: SQLite (file-based, no setup needed)
# Production: PostgreSQL (managed service for reliability)

# DATABASE_POOL_SIZE - Maximum persistent connections
# Development: 5 (small, local)
# Production: 50 (handle production load)
# More connections = faster but uses more memory

# DATABASE_MAX_OVERFLOW - Temporary connections beyond pool size
# Used when main pool is exhausted
# Development: 10 (small)
# Production: 100 (handle spikes)

# DATABASE_POOL_TIMEOUT - Wait time for connection (seconds)
# If no connection available after this time, request fails
# Default: 30 seconds

# DATABASE_POOL_RECYCLE - Recycle connections after (seconds)
# Prevents stale database connections (3600 = 1 hour)
# Default: 3600 seconds


# ============================================================================
# 3. REDIS CACHE
# ============================================================================
# What: Fast in-memory cache for embeddings
# Why: Embeddings are expensive to compute (seconds)
# Setup: Must be running before app starts!

# REDIS_URL - Connection string to Redis
# Format: redis://[password@]host:port/database
# Development: redis://localhost:6379/0 (local)
# Production: redis://managed-redis-host:6379/0
# Docker: redis://redis:6379/0 (service name)

# REDIS_TTL - Cache lifetime in seconds
# After this time, cached data expires and is recomputed
# Development: 1800 (30 minutes - easier testing)
# Production: 7200 (2 hours - more caching)

# REDIS_MAX_CONNECTIONS - Maximum connections to Redis
# Prevents connection pool exhaustion
# Development: 10
# Production: 100


# ============================================================================
# 4. LLM (LANGUAGE MODEL) CONFIGURATION
# ============================================================================
# What: AI model that generates answers
# Options: Mistral (local, free), OpenAI (cloud, paid), Groq (cloud, fast)
# Strategy: Primary LLM with fallback

# PRIMARY_LLM_MODEL - Main model to use
# Values: mistral, openai, anthropic, groq
# Development: mistral (free, local)
# Production: openai (reliable, fast)

# FALLBACK_LLM_MODEL - If primary fails
# Values: mistral, openai, anthropic, groq (different from primary)
# Ensures service continues even if primary LLM is down

# LLM_PROVIDER - Current provider (set automatically)
# Don't change manually


# ============================================================================
# 4A. MISTRAL CONFIGURATION (Free via Ollama)
# ============================================================================
# Setup: Download Ollama → ollama pull mistral → ollama serve

# MISTRAL_BASE_URL - Where Ollama server is running
# Local: http://localhost:11434
# Docker: http://ollama:11434

# MISTRAL_MODEL - Model name to use
# Options: mistral:latest, llama2:latest, neural-chat:latest


# ============================================================================
# 4B. OPENAI CONFIGURATION (Paid)
# ============================================================================
# Setup: Account at openai.com → Generate API key → Add credits

# OPENAI_API_BASE - API endpoint (usually doesn't change)
# Value: https://api.openai.com/v1

# OPENAI_API_KEY - Your API key
# ⚠️ NEVER commit to GitHub! Use GitHub Secrets!
# Format: sk-proj-...

# OPENAI_TIMEOUT - API call timeout (seconds)
# If API doesn't respond, request fails


# ============================================================================
# 4C. ANTHROPIC CONFIGURATION (Optional)
# ============================================================================
# Setup: Account at anthropic.com → Generate API key

# ANTHROPIC_API_KEY - Your Claude API key
# Format: sk-ant-...


# ============================================================================
# 4D. GROQ CONFIGURATION (Fast, free tier available)
# ============================================================================
# Setup: Account at groq.com → Generate API key
# Free tier: 8000 requests/minute

# GROQ_API_KEY - Your Groq API key
# Format: gsk-...

# GROQ_MODEL - Model to use from Groq
# Options: llama-3.1-8b-instant (fast), llama-3.1-70b-versatile (powerful)


# ============================================================================
# 5. LLM GENERATION PARAMETERS
# ============================================================================
# What: Fine-tune how LLM generates responses

# LLM_TEMPERATURE - Controls randomness
# Range: 0.0 to 2.0
# 0.0: deterministic (always same answer)
# 0.5: balanced (some variety)
# 1.0+: creative/random
# Use 0.3-0.5 for Q&A, 0.7+ for creative tasks

# LLM_MAX_TOKENS - Maximum tokens in response
# ~1 token = 4 characters
# 1000 tokens ≈ 4000 characters
# More = longer response, slower generation

# LLM_TOP_P - Nucleus sampling probability
# 0.95 = consider tokens with top 95% cumulative probability
# Lower = more focused, Higher = more variety


# ============================================================================
# 6. EMBEDDING MODEL CONFIGURATION
# ============================================================================
# What: Converts text to vectors for semantic search
# Why: Required for similarity-based retrieval

# EMBEDDING_MODEL - Model from HuggingFace
# Small (fast): all-MiniLM-L6-v2 (384D, 27MB)
# Large (better): all-mpnet-base-v2 (768D, 420MB)

# VECTOR_DIMENSION - Embedding vector size
# ⚠️ MUST MATCH YOUR FAISS INDEX!
# all-MiniLM-L6-v2 → 384
# all-mpnet-base-v2 → 768

# HF_TOKEN - HuggingFace API token
# Optional: needed only for downloading models
# Get from: https://huggingface.co/settings/tokens


# ============================================================================
# 7. DOCUMENT CHUNKING
# ============================================================================
# What: Split documents into smaller pieces for embedding

# CHUNK_SIZE - Size of each chunk (characters)
# Larger chunks = more context, slower
# Smaller chunks = specific, but may miss connections
# Typical: 512 (development) to 768 (production)

# CHUNK_OVERLAP - Overlap between chunks (characters)
# Prevents losing information at boundaries
# Typical: 10-20% of CHUNK_SIZE

# MIN_CHUNK_SIZE - Discard smaller chunks
# Typical: 100 characters

# MAX_CHUNK_SIZE - Split larger chunks
# Typical: 800-1000 characters

# CHUNK_QUALITY_THRESHOLD - Quality filter (0.0-1.0)
# Lower quality chunks are filtered out


# ============================================================================
# 8. VECTOR STORE (FAISS)
# ============================================================================
# What: Stores pre-computed embeddings for fast search

# FAISS_INDEX_PATH - Path to FAISS index file
# Binary format storing vectors

# FAISS_METADATA_PATH - Path to metadata file
# Pickle format mapping vector IDs to original text

# FAISS_BACKUP_PATH - Backup directory for indexes


# ============================================================================
# 9. QUERY PROCESSING
# ============================================================================
# What: Settings for processing user queries

# QUERY_TOP_K - Top K documents to retrieve
# Higher = more context, potentially more noise
# Typical: 5

# QUERY_MIN_LENGTH - Minimum query length (characters)
# Shorter queries are rejected as too vague

# QUERY_MAX_LENGTH - Maximum query length (characters)

# QUERY_TIMEOUT - Query processing timeout (seconds)
# Prevents hanging requests

# CONFIDENCE_THRESHOLD - Similarity threshold (0.0-1.0)
# Only documents above this are used as context
# Higher = stricter filtering
# Development: 0.5 | Production: 0.6


# ============================================================================
# 10. HALLUCINATION DETECTION
# ============================================================================
# What: Detect when LLM generates false information

# HALLUCINATION_THRESHOLD - Detection threshold (0.0-1.0)
# Lower = stricter (more likely to flag as hallucination)
# Development: 0.2 | Production: 0.15


# ============================================================================
# 11. EMBEDDING CACHE
# ============================================================================
# What: Cache computed embeddings to avoid re-computation

# EMBEDDING_CACHE_TTL - Cache lifetime (seconds)
# 2592000 = 30 days
# After this time, re-compute embeddings

# EMBEDDING_BATCH_SIZE - Batch size for computing
# Larger = faster but uses more memory

# ENABLE_EMBEDDING_CACHE - Enable/disable cache
# true: cache embeddings (faster, more memory)
# false: recompute each time (slower, less memory)


# ============================================================================
# 12. FILE UPLOAD
# ============================================================================
# What: Settings for document uploads

# MAX_UPLOAD_SIZE_MB - Maximum upload size (MB)

# UPLOAD_DIR - Directory to store uploads

# STORAGE_TYPE - Storage backend
# Values: local (filesystem) or s3 (AWS)


# ============================================================================
# 13. S3 CLOUD STORAGE (Optional)
# ============================================================================
# What: Cloud storage for documents

# S3_BUCKET - S3 bucket name
# Example: ragapp-prod-documents

# S3_REGION - AWS region
# Examples: us-east-1, eu-west-1


# ============================================================================
# 14. SECURITY & AUTHENTICATION
# ============================================================================
# What: API security and user authentication

# SECRET_KEY - JWT token signing key
# ⚠️ CRITICAL: Must be strong and random!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ NEVER commit to GitHub! Use GitHub Secrets!

# JWT_ALGORITHM - Algorithm for signing tokens
# Value: HS256 (HMAC)

# JWT_EXPIRATION_HOURS - Token expiration time
# Shorter = more secure but requires more refreshes
# Development: 24 (relaxed) | Production: 1 (strict)

# JWT_REFRESH_EXPIRATION_DAYS - Refresh token expiration
# Allows getting new access token without re-login


# ============================================================================
# 15. RATE LIMITING
# ============================================================================
# What: Prevent API abuse

# RATE_LIMIT_ENABLED - Enable rate limiting
# Development: false (easier testing)
# Production: true (prevent abuse)

# RATE_LIMIT_QUERIES_PER_MINUTE - Max queries per minute
# Development: 1000 | Production: 30

# RATE_LIMIT_REQUESTS_PER_HOUR - Max requests per hour
# Development: 10000 | Production: 1000


# ============================================================================
# 16. LOGGING
# ============================================================================
# What: Application logging configuration

# LOG_LEVEL - Verbosity level
# DEBUG < INFO < WARNING < ERROR < CRITICAL
# Development: DEBUG | Production: WARNING

# LOG_FILE - Log file path

# LOG_FORMAT - Log message format


# ============================================================================
# 17. MONITORING & METRICS
# ============================================================================
# What: Prometheus metrics for observability

# ENABLE_PROMETHEUS - Enable metrics collection

# PROMETHEUS_PORT - Metrics endpoint port


# ============================================================================
# 18. DATA STORAGE PATHS
# ============================================================================
# What: Directory structure for data

# DATA_DIR - Main data directory

# BACKUP_DIR - Backup directory


# ============================================================================
# 19. BATCH PROCESSING
# ============================================================================
# What: Background jobs

# BATCH_PROCESSING_ENABLED - Enable/disable batch jobs

# BATCH_PROCESSING_SCHEDULE - Cron schedule for jobs
# Format: minute hour day month weekday
# "0 2 * * *" = Every day at 2 AM


# ============================================================================
# 20. DEMO MODE
# ============================================================================
# What: Test without real LLM

# DEMO_MODE - Use dummy data
# true: dummy data (testing)
# false: real LLM (production)


