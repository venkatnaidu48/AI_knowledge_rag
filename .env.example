# RAG Application Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=RAG System
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# OpenAI Configuration (Primary LLM)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Groq Configuration (Fallback LLM)
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace Token (For embeddings)
HF_TOKEN=hf_your-huggingface-token-here

# Database Configuration
DATABASE_URL=sqlite:///./rag_dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/rag_db

# Vector Database
FAISS_INDEX_PATH=data/vector_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# Quality Settings
MIN_QUALITY_THRESHOLD=0.70
DEFAULT_TOP_K=5
MAX_CONTEXT_LENGTH=4000
QUALITY_CHECK_ENABLED=true

# Performance
CACHE_ENABLED=true
CACHE_TTL_MINUTES=60
ENABLE_ASYNC=true

# Security (Authentication)
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Monitoring
ENABLE_METRICS=true
PROMETHEUS_PORT=8001

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Logging
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Testing
TEST_DATABASE=sqlite:///./test_rag.db
PYTEST_TIMEOUT=300
